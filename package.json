{
  "name": "restaurant-kitchen-backend",
  "version": "1.0.0",
  "description": "Phân hệ quản lý bếp nhà hàng (Module Kitchen) - Hệ thống Real-time KDS & Thực đơn ngày",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch --runInBand",
    "test:coverage": "jest --coverage --runInBand",
    "test:auth": "jest tests/auth.test.js --runInBand"
  },
  "keywords": [
    "express",
    "mssql",
    "socket.io",
    "restaurant",
    "kitchen",
    "kds"
  ],
  "author": "Thành viên A - Hạ tầng",
  "license": "ISC",
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "joi": "^17.13.1",
    "mssql": "^10.0.2",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "testTimeout": 10000,
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/**/*.test.js"
    ],
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/config/",
      "src/utils/constants.js",
      "src/utils/helpers.js",
      "src/api/services/masterMenu.service.js",
      "src/api/services/dish.service.js",
      "src/api/services/dailyMenu.service.js",
      "src/api/services/order.service.js",
      "src/api/services/kitchen.service.js",
      "src/api/services/notification.service.js"
    ],
    "coverageDirectory": "coverage",
    "coverageReporters": [
      "text",
      "lcov",
      "html"
    ]
  }
}